{
  "name": "kygger",
  "version": "0.2.0",
  "description": "API types generator and client factory for OpenAPI",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "kygger": "bin/kygger.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/generator.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/generator.ts --format cjs,esm --watch --dts",
    "prepublishOnly": "npm run build",
    "lint": "eslint --fix",
    "format": "prettier --write",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install",
  },
  "dependencies": {
    "ky": "^1.14.3",
    "openapi-zod-client": "^1.18.3",
    "prettier": "^3.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.30",
    "ajv": "^8.18.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "lefthook": "^2.1.6",
    "tsup": "^8.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "type": "module"
}
